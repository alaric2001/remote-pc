# ============================================================
# Remote PC Control — Template Environment Variable
# Salin file ini menjadi .env dan isi dengan nilai sebenarnya
# JANGAN commit file .env ke repository
# ============================================================

# --- SERVER ---
HOST=0.0.0.0
PORT=8000

# Secret key untuk signing JWT (ganti dengan string acak yang panjang)
JWT_SECRET=ganti_dengan_secret_key_yang_kuat_dan_panjang
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- AGENT ---
# URL WebSocket relay server (ganti dengan ngrok URL saat deploy)
SERVER_URL=ws://localhost:8000/ws/agent

# Token autentikasi agent (harus cocok dengan yang ada di server)
AGENT_TOKEN=ganti_dengan_token_agent_yang_aman

# Kecepatan pengiriman screenshot (frame per detik)
SCREENSHOT_FPS=30

# Kualitas JPEG screenshot (1-100, makin rendah makin kecil ukurannya)
SCREENSHOT_QUALITY=35

# Delay sebelum mencoba reconnect (detik)
RECONNECT_DELAY=3

# --- NGROK ---
NGROK_AUTH_TOKEN=
NGROK_STATIC_DOMAIN=
